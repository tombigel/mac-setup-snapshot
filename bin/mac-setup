#!/usr/bin/env bash

set -u

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
PROJECT_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/common.sh
. "$PROJECT_DIR/lib/common.sh"
# shellcheck source=../lib/args.sh
. "$PROJECT_DIR/lib/args.sh"
# shellcheck source=../lib/endpoint.sh
. "$PROJECT_DIR/lib/endpoint.sh"
# shellcheck source=../lib/config.sh
. "$PROJECT_DIR/lib/config.sh"
# shellcheck source=../lib/safety.sh
. "$PROJECT_DIR/lib/safety.sh"
# shellcheck source=../lib/report.sh
. "$PROJECT_DIR/lib/report.sh"
# shellcheck source=../lib/inventory.sh
. "$PROJECT_DIR/lib/inventory.sh"
# shellcheck source=../lib/gist.sh
. "$PROJECT_DIR/lib/gist.sh"
# shellcheck source=../lib/workflow.sh
. "$PROJECT_DIR/lib/workflow.sh"

for source_file in "$PROJECT_DIR"/lib/sources/*.sh; do
  # shellcheck source=/dev/null
  . "$source_file"
done

main() {
  mi_args_init

  if [ "$#" -eq 0 ]; then
    mi_show_help
    return 0
  fi

  if ! mi_parse_args "$@"; then
    return 2
  fi

  if [ "$MI_HELP" = "true" ] || [ "$MI_COMMAND" = "help" ]; then
    mi_show_help
    return 0
  fi

  mi_endpoint_resolve_config_path || return $?
  mi_config_apply
  mi_endpoint_resolve || return $?
  mi_report_start

  rc=0

  if [ "$MI_GIST_PULL" = "true" ] && [ "$MI_COMMAND" != "gist" ]; then
    mi_gist_pull || rc=$?
  fi

  if [ "$rc" -eq 0 ]; then
    case "$MI_COMMAND" in
      backup)
        mi_endpoint_prepare_backup && mi_inventory_backup && mi_endpoint_write_metadata
        rc=$?
        ;;
      restore)
        mi_inventory_restore
        rc=$?
        ;;
      prepare)
        mi_workflow_run "prepare"
        rc=$?
        ;;
      continue)
        mi_workflow_continue
        rc=$?
        ;;
      status)
        mi_resume_reset_if_requested || rc=$?
        [ "$rc" -eq 0 ] && { mi_resume_status; rc=$?; }
        ;;
      list)
        mi_inventory_list
        rc=$?
        ;;
      doctor)
        mi_doctor
        rc=$?
        ;;
      config)
        if [ "$MI_SUBCOMMAND" = "generate" ]; then
          mi_config_generate
          rc=$?
        else
          mi_error "unknown config command: ${MI_SUBCOMMAND:-<missing>}"
          rc=2
        fi
        ;;
      gist)
        case "$MI_SUBCOMMAND" in
          pull) mi_gist_pull; rc=$? ;;
          push) mi_gist_push; rc=$? ;;
          *)
            mi_error "unknown gist command: ${MI_SUBCOMMAND:-<missing>}"
            rc=2
            ;;
        esac
        ;;
      *)
        mi_error "unknown command: $MI_COMMAND"
        rc=2
        ;;
    esac
  fi

  if [ "$MI_GIST_PUSH" = "true" ] && [ "$MI_COMMAND" != "gist" ]; then
    [ "$rc" -eq 0 ] && { mi_gist_push || rc=$?; }
  fi

  mi_report_finish "$rc"
  return "$rc"
}

main "$@"
