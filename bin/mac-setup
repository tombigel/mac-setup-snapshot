#!/bin/zsh -f

emulate -R zsh
setopt no_unset no_nomatch sh_word_split

MI_SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${MI_SCRIPT_PATH:h}"
PROJECT_DIR="${SCRIPT_DIR:h}"

. "$PROJECT_DIR/lib/common.zsh"
. "$PROJECT_DIR/lib/args.zsh"
. "$PROJECT_DIR/lib/endpoint.zsh"
. "$PROJECT_DIR/lib/config.zsh"
. "$PROJECT_DIR/lib/safety.zsh"
. "$PROJECT_DIR/lib/report.zsh"
. "$PROJECT_DIR/lib/inventory.zsh"
. "$PROJECT_DIR/lib/ignore.zsh"
. "$PROJECT_DIR/lib/gist.zsh"
. "$PROJECT_DIR/lib/workflow.zsh"
. "$PROJECT_DIR/lib/wizard.zsh"

for source_file in "$PROJECT_DIR"/lib/sources/*.zsh; do
  . "$source_file"
done

main() {
  rc=0

  mi_args_init

  if [ "$#" -eq 0 ]; then
    if mi_wizard_interactive; then
      set -- wizard
    else
      mi_show_help
      return 0
    fi
  fi

  if ! mi_parse_args "$@"; then
    return 2
  fi

  if [ "$MI_HELP" = "true" ] || [ "$MI_COMMAND" = "help" ]; then
    mi_show_help
    return 0
  fi

  if [ "$MI_COMMAND" = "wizard" ]; then
    case "$MI_SUBCOMMAND" in
      "")
        mi_wizard_run
        rc=$?
        ;;
      backup|restore)
        mi_wizard_run "$MI_SUBCOMMAND"
        rc=$?
        ;;
      config)
        mi_error "wizard config is committed in the repo; edit mac-setup.wizard.yml or pass --wizard-config"
        rc=2
        ;;
      *)
        mi_error "unknown wizard command: ${MI_SUBCOMMAND:-<missing>}"
        rc=2
        ;;
    esac
    mi_cleanup_temp_files
    return "$rc"
  fi

  mi_endpoint_resolve_config_path || return $?
  mi_config_apply
  mi_endpoint_resolve || return $?
  mi_report_start

  if [ "$MI_GIST_PULL" = "true" ] && [ "$MI_COMMAND" != "gist" ]; then
    mi_gist_pull || rc=$?
  fi

  if [ "$rc" -eq 0 ]; then
    case "$MI_COMMAND" in
      backup)
        mi_endpoint_prepare_backup && mi_inventory_backup && mi_endpoint_write_metadata
        rc=$?
        ;;
      restore)
        mi_inventory_restore
        rc=$?
        ;;
      prepare)
        mi_workflow_run "prepare"
        rc=$?
        ;;
      continue)
        mi_workflow_continue
        rc=$?
        ;;
      status)
        mi_resume_reset_if_requested || rc=$?
        [ "$rc" -eq 0 ] && { mi_resume_status; rc=$?; }
        ;;
      list)
        mi_inventory_list
        rc=$?
        ;;
      ignore|unignore)
        mi_ignore_command "$MI_COMMAND"
        rc=$?
        ;;
      doctor)
        mi_doctor
        rc=$?
        ;;
      config)
        if [ "$MI_SUBCOMMAND" = "generate" ]; then
          mi_config_generate
          rc=$?
        else
          mi_error "unknown config command: ${MI_SUBCOMMAND:-<missing>}"
          rc=2
        fi
        ;;
      gist)
        case "$MI_SUBCOMMAND" in
          pull) mi_gist_pull; rc=$? ;;
          push) mi_gist_push; rc=$? ;;
          *)
            mi_error "unknown gist command: ${MI_SUBCOMMAND:-<missing>}"
            rc=2
            ;;
        esac
        ;;
      *)
        mi_error "unknown command: $MI_COMMAND"
        rc=2
        ;;
    esac
  fi

  if [ "$MI_GIST_PUSH" = "true" ] && [ "$MI_COMMAND" != "gist" ]; then
    [ "$rc" -eq 0 ] && { mi_gist_push || rc=$?; }
  fi

  mi_report_finish "$rc"
  mi_cleanup_temp_files
  return "$rc"
}

main "$@"
